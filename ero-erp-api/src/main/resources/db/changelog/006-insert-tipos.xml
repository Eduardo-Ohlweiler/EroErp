<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="006-insert-tipos" author="eduardo">

        <!-- TIPO TELEFONE -->
        <insert tableName="tipo_telefone">
            <column name="nome" value="Celular"/>
            <column name="ativo" valueBoolean="true"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>

        <insert tableName="tipo_telefone">
            <column name="nome" value="WhatsApp"/>
            <column name="ativo" valueBoolean="true"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>

        <insert tableName="tipo_telefone">
            <column name="nome" value="Residencial"/>
            <column name="ativo" valueBoolean="true"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>


        <!-- TIPO EMAIL -->
        <insert tableName="tipo_email">
            <column name="nome" value="Comercial"/>
            <column name="ativo" valueBoolean="true"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>

        <insert tableName="tipo_email">
            <column name="nome" value="Particular"/>
            <column name="ativo" valueBoolean="true"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>


        <!-- TIPO ENDERECO -->
        <insert tableName="tipo_endereco">
            <column name="nome" value="Residencial"/>
            <column name="ativo" valueBoolean="true"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>

        <insert tableName="tipo_endereco">
            <column name="nome" value="Comercial"/>
            <column name="ativo" valueBoolean="true"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>

    </changeSet>

</databaseChangeLog>